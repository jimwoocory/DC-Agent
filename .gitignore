# ────────────────────────────────────────────────────────────────────
# DC-Agent 定制层（fork v4.24.5 之上的 dc-agent/main 分支专用）
# ────────────────────────────────────────────────────────────────────

# 覆盖 AstrBot 默认 "data" 整个 ignore：白名单我们要的 data/ 子项
!data/
!data/plugins/
!data/plugins/**
!data/config/
!data/config/hermes_bridge_config.json
!data/config/openclaw_on_demand_config.json
!data/feishu_whitelist.example.yaml

# Treat config as sensitive by default; explicitly unignore reviewed templates/configs.
data/config/*.json
data/config/*.yaml
data/config/*.yml
!data/config/hermes_bridge_config.json
!data/config/openclaw_on_demand_config.json
!data/config/system_entries_config.json

# 再 ignore 我们的 plugin 下的 __pycache__ / pyc
data/plugins/**/__pycache__/
data/plugins/**/*.pyc

# DC-Agent hygiene: runtime backups and generated scratch output
**/_backup_*.py
**/*_backup_*.py
**/*.bak
**/*.bak.*
**/*.py.bak
**/tmp/
**/output/
**/logs/
data/_backup_*/
data/_backup_*
data/*backup*/
data/*backup*
data/config/_backup_*
data/plugins/**/_backup_*
data/temp/
data/output/
cache/
conversions/
outputs/

# ────────────────────────────────────────────────────────────────────
